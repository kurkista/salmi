{
  "name": "tutka",
  "version": "0.2.0",
  "description": "tutka — a civic/OSINT threat-monitoring platform for Finland. Nordic/Baltic tension, information environment, and more, one domain at a time.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "vite build --config web/vite.config.ts",
    "start": "node server/index.js",
    "test": "node --test server/test/*.test.js"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "echarts": "^5.5.0",
    "maplibre-gl": "^5.0.0",
    "marked": "^15.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
