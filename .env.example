# Copy to .env (gitignored) and fill in. Never commit real values.

# AIS live ship data — register a free key at https://aisstream.io (GitHub login).
# Without a key the app still runs; the live vessel layer is just disabled.
AISSTREAM_API_KEY=

# OpenSky Network flight layer (M3) — free account at https://opensky-network.org,
# then create an API client (OAuth2 client credentials) in your account settings.
#OPENSKY_CLIENT_ID=
#OPENSKY_CLIENT_SECRET=

# Shared secret for POST /api/ingest/gdelt (the news-relay GitHub Action).
# Generate with: openssl rand -hex 24 — set the same value as a fly secret and
# as the INGEST_TOKEN repo Actions secret.
#INGEST_TOKEN=

# Server
PORT=8080
DB_PATH=./dev.db
